{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-lmstudio@latest"],
  "provider": {
    "argo": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Argo",
      "options": {
        "baseURL": "http://0.0.0.0:62208/v1",
        "apiKey": "ryan.lewis"
      },
      "models": {
        "argo:gpt-5.2": {
          "name": "gpt52",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "argo:gpt-5": {
          "name": "gpt5"
        },
        "argo:gpt-5-mini": {
          "name": "gpt5mini"
        },
        "argo:gpt-5-nano": {
          "name": "gpt5nano"
        },
        "argo:gpt-5.1": {
          "name": "gpt51",
          "limit": {
            "context": 10000,
            "output": 5000
          }
        },
        "argo:gpt-4-32k": {
          "name": "gpt4large"
        },
        "argo:gpt-4-turbo": {
          "name": "gpt4turbo"
        },
        "argo:gpt-4o": {
          "name": "gpt4o"
        },
        "argo:gpt-o1-preview": {
          "name": "gpto1preview"
        },
        "argo:o1-preview": {
          "name": "gpto1preview"
        },
        "argo:gpt-4o-latest": {
          "name": "gpt4olatest"
        },
        "argo:gpt-o1-mini": {
          "name": "gpto1mini",
          "limit": {
            "context": 10000,
            "output": 5000
          }
        },
        "argo:gemini-2.5-pro": {
          "name": "gemini25pro"
        },
        "argo:gemini-2.5-flash": {
          "name": "gemini25flash"
        },
        "argo:claude-4.5-opus": {
          "name": "claudeopus45",
          "family": "anthropic",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            },
            "temperature": 0.7
          },
          "limit": {
            "context": 200000,
            "output": 20999
          }
        },
        "argo:claude-opus-4.5": {
          "name": "opus45",
          "family": "anthropic",
          "limit": {
            "context": 200000,
            "output": 20999
          }
        },
        "argo:claude-4.5-haiku": {
          "name": "claudehaiku45",
          "family": "anthropic",
          "limit": {
            "context": 200000,
            "output": 20999
          }
        },
        "argo:claude-haiku-4.5": {
          "name": "haiku45",
          "family": "anthropic",
          "limit": {
            "context": 200000,
            "output": 20999
          }
        },
        "argo:claude-4.5-sonnet": {
          "name": "claudesonnet45",
          "family": "anthropic",
          "limit": {
            "context": 200000,
            "output": 20999
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        },
        "argo:claude-sonnet-4.5": {
          "name": "sonnet45",
          "family": "anthropic",
          "limit": {
            "context": 200000,
            "output": 20999
          }
        }
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      }
    }
  }
}
